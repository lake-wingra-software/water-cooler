# Required: API key for Anthropic LLM
ANTHROPIC_API_KEY=abc

# Use another LLM Provider (Optional):
ANTHROPIC_URL=http://

# LLM Model to use for character brains (optional)
# Available models: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
LLM_MODEL=claude-haiku-4-5

# Simulation speed: ticks per second (0 for instant execution)
# TICKS_PER_SEC=8
